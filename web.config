<?xml version="1.0" encoding="UTF-8"?>
<!--
  Only needed if this app sits behind IIS via the two-process PM2 setup
  (ecosystem.config.cjs: minutemind-backend on 6005, minutemind-frontend on
  6006 — clear of AssetDisposal's 6002/6003 so both can run on the same box).
  Requires the IIS Application Request Routing + URL Rewrite modules. Not
  needed if run.bat is used standalone on its own port (4001).
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="API Backend" stopProcessing="true">
          <match url="^api/(.*)" />
          <action type="Rewrite" url="http://localhost:6005/api/{R:1}" />
        </rule>
        <rule name="Frontend" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:6006/{R:1}" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
